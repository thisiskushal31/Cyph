# Dev image: run with source mounted; polling entrypoint recompiles and restarts when source changes.
FROM eclipse-temurin:17-jdk
WORKDIR /app

# Gradle wrapper + build config (src comes from mount so image works for CI/cache)
COPY gradlew ./
COPY gradle gradle
COPY build.gradle.kts settings.gradle.kts ./
COPY docker-entrypoint.dev.sh ./

EXPOSE 8080
# Poll for changes every 2s so bind-mounted code updates apply without container restart (Mac/Windows)
CMD ["sh", "./docker-entrypoint.dev.sh"]
