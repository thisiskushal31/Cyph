{
  "id": "cyph",
  "realm": "cyph",
  "enabled": true,
  "displayName": "Cyph (local SSO)",
  "clients": [
    {
      "clientId": "cyph-backend",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "cyph-backend-secret",
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:4200/login/oauth2/code/keycloak",
        "http://localhost:8080/login/oauth2/code/keycloak"
      ],
      "webOrigins": ["http://localhost:4200", "http://localhost:8080"]
    }
  ],
  "users": [
    {
      "username": "sso-user",
      "enabled": true,
      "email": "sso-user@cyph.local",
      "firstName": "SSO",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "sso-user",
          "temporary": true
        }
      ]
    }
  ]
}
